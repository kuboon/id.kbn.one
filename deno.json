{
  "nodeModulesDir": "auto",
  "tasks": {
    "test": "deno fmt && deno lint && deno check && deno test -P",
    "dev": "deno task --cwd=main dev",
    "serve": "deno task --cwd=main serve",
    "pre-deploy": "echo \"nothing to do\""
  },
  "workspace": [
    "main",
    "passkeys",
    "dpop"
  ],
  "imports": {
    "@hexagon/base64": "npm:@hexagon/base64@2.0.4",
    "@hono/standard-validator": "jsr:@hono/standard-validator@^0.2.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "arktype": "npm:arktype@^2.2.0",
    "hono": "jsr:@hono/hono@^4.12.14"
  },
  "unstable": ["kv", "bundle"],
  "deploy": {
    "org": "kuboon-tokyo",
    "app": "id-kbn-one"
  },
  "permissions": {
    "default": {
      "env": [
        "RP_ID",
        "RP_NAME",
        "IDP_ORIGIN",
        "AUTHORIZE_WHITELIST",
        "PUSH_CONTACT",
        "DENO_KV_ACCESS_TOKEN"
      ],
      "net": [
        "kv.localhost:80",
        "kvdp.localhost:80",
        "updates.push.services.mozilla.com"
      ],
      "read": ["."],
      "write": ["./_data"]
    }
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-slow-types"
      ]
    }
  }
}
