{
  "imports": {
    "@negrel/webpush": "jsr:@negrel/webpush@^0.5.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/media-types": "jsr:@std/media-types@^1.1.0"
  },
  "tasks": {
    "dev": "cd .. && deno task bundle && deno serve -P --watch=main main/deno-server.ts",
    "serve": "cd .. && deno serve -P main/deno-server.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@remix-run/component"
  }
}
